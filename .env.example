# Copy this file to .env and fill in your values
#   copy .env.example .env

FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key

# Database (optional — defaults to SQLite school.db in project root)
# DATABASE_URL=sqlite:///school.db

# Gemini AI — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Email (Flask-Mail) — optional for contact/admission notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
SCHOOL_EMAIL=school@example.com

# School Information
SCHOOL_NAME=Blue Bells Public School
SCHOOL_TAGLINE=Transforming Education for Tomorrow
SCHOOL_PHONE=+91 98765 43210
SCHOOL_ADDRESS=123 Education Lane, Knowledge City, India 110001

# Rate Limiting (optional)
# RATELIMIT_STORAGE_URI=memory://
